---
# Git identity
git_user_name: "Your Name"
git_user_email: "you@example.com"

# Data disk
data_disk_mountpoint: /docker-data
immich_data_location: "{{ data_disk_mountpoint }}/volumes/immich"

# Tailscale
tailscale_tag: "server"               # role prepends "tag:" automatically
tailscale_authkey_secret: "TS_MACHINENAME_AUTH_KEY"  # Infisical secret name
tailscale_subnet: "192.168.1.0/24"   # advertise-routes subnet (leave blank to skip)
tailscale_exit_node: false            # advertise as exit node

# DNS
dns_hostname: "machinename"           # <dns_hostname>.swintronics.com A/AAAA records
dns_services:                         # CNAMEs pointing to dns_hostname
  - traefik
  - dozzle
