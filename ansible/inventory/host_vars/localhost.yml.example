---
# Host identity
admin_user: "your-name"              # OS user on this server

# Git identity (local hosts only)
git_user_name: "Your Name"
git_user_email: "you@example.com"

# Tailscale
tailscale_tag: "server"               # role prepends "tag:" automatically
tailscale_authkey_secret: "TS_AUTH_KEY"  # Infisical secret name
tailscale_subnet: "192.168.1.0/24"   # advertise-routes subnet (leave blank to skip)
tailscale_exit_node: false            # advertise as exit node

# DNS
dns_hostname: "myhostname"           # <dns_hostname>.<server_domain> A record

# Storage
use_btrfs: true                      # false to use plain directories instead of btrfs subvolumes

# Docker
docker_gid: "984"                    # Check with: getent group docker | cut -d: -f3

# Hardware (optional)
# hardware_watchdog_module: "iTCO_wdt"
