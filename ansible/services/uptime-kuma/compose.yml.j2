# Managed by Ansible. Do not edit — changes will be overwritten on next deployment.

include:
  - ../networks.yml

services:
  uptime-kuma:
    container_name: uptime-kuma
    image: louislam/uptime-kuma:{{ versions.kuma }}
    restart: unless-stopped
    volumes:
      - {{ data_disk_mountpoint }}/volumes/uptime-kuma/data:/app/data
      - /var/run/docker.sock:/var/run/docker.sock
    extra_hosts:
      - "host.docker.internal:host-gateway"
    ports:
      # <Host Port>:<Container Port>
      - "3001:3001"
    labels:

      # Shared service definition
      traefik.enable: true
      traefik.http.services.kuma-service.loadbalancer.server.port: 3001

      # Uptime Kuma Status Page Router
      traefik.http.routers.uptime-kuma.entrypoints: websecure
      traefik.http.routers.uptime-kuma.rule: Host(`{{ _service_config.kuma.dns_names[0] }}.{{ server_domain }}`)
      traefik.http.routers.uptime-kuma.tls.certresolver: ${CERT_RESOLVER}
      traefik.http.routers.uptime-kuma.service: kuma-service
      traefik.http.routers.uptime-kuma.middlewares: redirect-status

      # Uptime Kuma Admin Interface Router
      traefik.http.routers.status-admin.entrypoints: websecure
      traefik.http.routers.status-admin.rule: Host(`{{ _service_config.kuma.dns_names[1] }}.{{ server_domain }}`)
      traefik.http.routers.status-admin.tls.certresolver: ${CERT_RESOLVER}
      traefik.http.routers.status-admin.service: kuma-service
      traefik.http.routers.status-admin.middlewares: kuma-headers

      # WebSocket support — Kuma requires these headers for WS upgrades through a reverse proxy
      traefik.http.middlewares.kuma-headers.headers.customrequestheaders.X-Forwarded-Proto: https
      traefik.http.middlewares.kuma-headers.headers.customrequestheaders.Upgrade: websocket
      traefik.http.middlewares.kuma-headers.headers.customrequestheaders.Connection: Upgrade

      # Middleware to redirect to /status/default
      traefik.http.middlewares.redirect-status.redirectregex.regex: "^https://{{ _service_config.kuma.dns_names[0] }}\\.[^/]+/?$"
      traefik.http.middlewares.redirect-status.redirectregex.replacement: "https://{{ _service_config.kuma.dns_names[0] }}.{{ server_domain }}/status/default"
      traefik.http.middlewares.redirect-status.redirectregex.permanent: true
