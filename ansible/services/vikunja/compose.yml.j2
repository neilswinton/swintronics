# Managed by Ansible. Do not edit — changes will be overwritten on next deployment.

name: vikunja

include:
  - ../networks.yml

services:
  vikunja:
    image: vikunja/vikunja:{{ versions.vikunja }}
    env_file:
      - .env
    environment:
      VIKUNJA_SERVICE_PUBLICURL: https://{{ _service_config.vikunja.dns_names[0] }}.{{ server_domain }}/
      VIKUNJA_DATABASE_PATH: /db/vikunja.db
    volumes:
      - {{ data_disk_mountpoint }}/volumes/vikunja/files:/app/vikunja/files
      - {{ data_disk_mountpoint }}/volumes/vikunja/db:/db
    restart: unless-stopped
    labels:
      traefik.enable: true
      traefik.http.routers.vikunja.entrypoints: websecure
      traefik.http.routers.vikunja.rule: Host(`{{ _service_config.vikunja.dns_names[0] }}.{{ server_domain }}`)
      traefik.http.routers.vikunja.tls.certresolver: ${CERT_RESOLVER}
      traefik.http.services.vikunja.loadbalancer.server.port: 3456
