#!/bin/bash
set -euo pipefail
# Upload linkwarden snapshot to restic.

SNAP_DIR="${DATA_MOUNTPOINT:-/mnt/docker-data}/snapshots/linkwarden/nightly"

echo "Uploading linkwarden snapshot to restic..."
sudo -E restic backup --tag linkwarden --tag "${DATE:-$(date +%F_%H-%M)}" "${SNAP_DIR}"
sudo -E restic forget --tag linkwarden --keep-daily 7 --keep-weekly 4 --prune
sudo -E restic check

[ -n "${KUMA_LINKWARDEN_PUSH_URL:-}" ] && curl -fsS -o /dev/null --retry 3 "${KUMA_LINKWARDEN_PUSH_URL}" || true
