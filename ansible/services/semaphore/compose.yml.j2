# Managed by Ansible. Do not edit — changes will be overwritten on next deployment.

name: semaphore

include:
  - ../networks.yml

services:
  semaphore:
    image: semaphoreui/semaphore:{{ versions.semaphore }}
    env_file:
      - .env
    environment:
      SEMAPHORE_DB_DIALECT: sqlite
      SEMAPHORE_DB: /data/semaphore.sqlite
      SEMAPHORE_PLAYBOOK_PATH: /tmp/semaphore
      SEMAPHORE_ADMIN: admin
      SEMAPHORE_ADMIN_NAME: admin
      SEMAPHORE_ADMIN_EMAIL: admin@{{ server_domain }}
      TZ: "{{ timezone | default('UTC') }}"
    volumes:
      - {{ data_disk_mountpoint }}/volumes/semaphore/data:/data
      - {{ data_disk_mountpoint }}/volumes/semaphore/tmp:/tmp/semaphore
    restart: always
    labels:
      traefik.enable: true
      traefik.http.routers.semaphore.entrypoints: websecure
      traefik.http.routers.semaphore.rule: Host(`{{ _service_config.semaphore.dns_names[0] }}.{{ server_domain }}`)
      traefik.http.routers.semaphore.tls.certresolver: ${CERT_RESOLVER}
      traefik.http.services.semaphore.loadbalancer.server.port: 3000
