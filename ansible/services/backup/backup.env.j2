# Managed by Ansible. Do not edit — changes will be overwritten on next deployment.
# Sourced by docker-services/cluster.sh, docker-services/backup.sh,
# and per-service backup-prepare/backup-execute/backup-remote scripts.

# B2 credentials used via B2's S3-compatible API (restic's s3 backend).
# B2's native API auth (b2_authorize_account) currently rejects v1/v2/v3, so we
# go through S3 instead. Same underlying storage either way.
export AWS_ACCESS_KEY_ID="{{ infisical_secrets.secrets.B2_ACCOUNT_ID }}"
export AWS_SECRET_ACCESS_KEY="{{ infisical_secrets.secrets.B2_ACCOUNT_KEY }}"
export RESTIC_REPOSITORY="{{ infisical_secrets.secrets.RESTIC_REPOSITORY }}"
export RESTIC_PASSWORD='{{ infisical_secrets.secrets.RESTIC_PASSWORD }}'

# Gatus backup push — token shared with gatus/.env, used by backup-remote scripts
export GATUS_BASE_URL="https://gatus.{{ server_domain }}"
export GATUS_BACKUP_PUSH_TOKEN="{{ infisical_secrets.secrets.GATUS_BACKUP_PUSH_TOKEN }}"

# Healthchecks.io heartbeat — paused while backups run, resumed after
export HEARTBEAT_HEALTHCHECK_UUID="{{ infisical_secrets.secrets.HEALTHCHECKS_HEARTBEAT_CHECK_UUID }}"
export HEARTBEAT_HEALTHCHECK_PAUSE_URL="https://healthchecks.io/api/v3/checks/${HEARTBEAT_HEALTHCHECK_UUID}/pause"
export HEARTBEAT_HEALTHCHECK_RESUME_URL="https://healthchecks.io/api/v3/checks/${HEARTBEAT_HEALTHCHECK_UUID}/resume"
export HEARTBEAT_HEALTHCHECK_API_KEY="{{ infisical_secrets.secrets.HEALTHCHECKS_API_KEY }}"

export DATA_MOUNTPOINT="{{ data_disk_mountpoint }}"
