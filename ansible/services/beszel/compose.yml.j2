# Managed by Ansible. Do not edit — changes will be overwritten on next deployment.

name: beszel
include:
  - ../networks.yml

services:
  beszel:
    image: henrygd/beszel:{{ versions.beszel }}
    container_name: beszel
    restart: always
    env_file: .env
    volumes:
      - {{ data_disk_mountpoint }}/volumes/beszel/beszel_data:/beszel_data
    labels:
      traefik.enable: true
      traefik.http.routers.beszel.entrypoints: websecure
      traefik.http.routers.beszel.rule: Host(`{{ _service_config.beszel.dns_names[0] }}.{{ server_domain }}`)
      traefik.http.routers.beszel.tls.certresolver: ${CERT_RESOLVER}
      traefik.http.services.beszel.loadbalancer.server.port: 8090

{% if beszel_agent_key is defined and beszel_agent_key %}
  beszel-agent:
    image: henrygd/beszel-agent:{{ versions.beszel }}
    container_name: beszel-agent
    restart: always
    network_mode: host
    healthcheck:
      test: ['CMD', '/agent', 'health']
      interval: 120s
    volumes:
      - {{ data_disk_mountpoint }}/volumes/beszel/beszel_agent_data:/var/lib/beszel-agent
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ data_disk_mountpoint }}:/extra-filesystems/sdb1__DockerData-1:ro
    environment:
      LISTEN: 45876
      KEY: "{{ beszel_agent_key }}"
      TOKEN: "{{ beszel_agent_token }}"
      HUB_URL: "https://{{ _service_config.beszel.dns_names[0] }}.{{ server_domain }}"
{% endif %}
