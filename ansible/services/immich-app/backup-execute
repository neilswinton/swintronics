#!/bin/bash
set -euo pipefail
# Stop immich, dump postgres, snapshot library volume, restart immich.
# Kuma is already stopped and healthchecks paused by the orchestrator.

DATA="${DATA_MOUNTPOINT:-/mnt/docker-data}"
SOURCE="${DATA}/volumes/immich/library"
SNAP_DIR="${DATA}/snapshots/immich/library/backup"
DB_DUMP="${SOURCE}/immich_db.sql"

mkdir -p "$(dirname "${SNAP_DIR}")"

# Clean up previous backup snapshot
if [ "$(stat --format=%i "${SNAP_DIR}" 2>/dev/null)" = "256" ]; then
    sudo btrfs property set "${SNAP_DIR}" ro false
    sudo btrfs subvolume delete "${SNAP_DIR}"
fi
if [ -e "${SNAP_DIR}" ]; then
    echo "ERROR: could not remove previous snapshot at ${SNAP_DIR}" >&2; exit 1
fi

echo "Stopping Immich services..."
docker compose stop immich-server immich-machine-learning

echo "Dumping Immich database..."
docker compose up -d database
docker compose exec database pg_dumpall --clean --if-exists -U postgres > "${DB_DUMP}"

echo "Creating btrfs snapshot at ${SNAP_DIR}..."
sudo btrfs subvolume snapshot -r "${SOURCE}" "${SNAP_DIR}"

echo "Starting Immich services..."
docker compose start immich-server immich-machine-learning
