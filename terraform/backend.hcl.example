# Terraform backend configuration — copy to backend.hcl and fill in values.
# backend.hcl is gitignored; each deployment has its own copy.
#
# AWS credentials are read from the environment:
#   export AWS_ACCESS_KEY_ID=<your-key-id>
#   export AWS_SECRET_ACCESS_KEY=<your-secret-key>
#
# For Cloudflare R2: create an R2 API token with Object Read & Write permissions.
# For Backblaze B2: use the application key ID and application key.

bucket = "your-bucket-name"
key    = "your-deployment-name/terraform.tfstate"

endpoints = {
  s3 = "https://<account-id>.r2.cloudflarestorage.com"
  # For Backblaze B2:
  # s3 = "https://s3.<region>.backblazeb2.com"
}
